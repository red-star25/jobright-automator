{
  "manifest_version": 3,
  "name": "InsiderReach",
  "version": "0.3.2",
  "description": "AI-assisted Jobright outreach for personalized Gmail drafts and LinkedIn connection notes.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab",
    "unlimitedStorage",
    "identity"
  ],
  "host_permissions": [
    "https://jobright.ai/*",
    "https://*.jobright.ai/*",
    "https://mail.google.com/*",
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://web-gamma-silk-53.vercel.app/*",
    "https://jobright-automator-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "InsiderReach",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://jobright.ai/*", "https://*.jobright.ai/*"],
      "js": ["config.js", "content_jobright.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content_gmail.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["content_linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
